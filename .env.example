# ===========================================
# Survey Platform – environment configuration
# ===========================================

# --- Backend ---
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://survey:survey@localhost:5432/survey_dev?schema=public

# Auth (JWT)
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Redis (optional, for caching and webhook queues)
REDIS_URL=redis://localhost:6379

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=Survey Platform

# --- Webhooks ---
WEBHOOK_SIGNING_SECRET=replace-me-with-another-long-random-secret
WEBHOOK_MAX_RETRIES=5
