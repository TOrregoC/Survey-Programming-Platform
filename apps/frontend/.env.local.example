# Frontend-local env. Copy to .env.local for `next dev`.

# Backend URL used by the Next.js server-side proxy (never exposed to the browser).
# Only needed if your backend runs somewhere other than http://localhost:5000.
# BACKEND_API_URL=http://localhost:5000

# Uncomment ONLY if you want the browser to call the backend directly (bypasses proxy).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

NEXT_PUBLIC_APP_NAME=Survey Platform
