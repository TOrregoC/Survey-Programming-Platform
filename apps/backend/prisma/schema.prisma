// Prisma schema for the Survey Platform.
//
// Design notes:
//   - Multi-tenant isolation: every domain table carries tenantId; every query
//     in services must filter by it (enforced by middleware-derived context).
//   - Survey content (blocks, questions, logic, quotas) lives in `Survey.structure`
//     as a JSON document — this matches our canonical SurveyDocument schema and
//     keeps versioning/serialization trivial. Snapshots go to SurveyVersion.
//   - Responses store both the version they were captured against and a JSON
//     bag of answers keyed by question id, so analytics survives survey edits.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SurveyStatus {
  draft
  published
  closed
  archived
}

enum ResponseStatus {
  started
  in_progress
  completed
  abandoned
}

enum UserRole {
  admin
  editor
  viewer
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  subdomain String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  surveys       Survey[]
  responses     Response[]
  webhooks      WebhookSubscription[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  role         UserRole @default(editor)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownedSurveys   Survey[]   @relation("SurveyOwner")
  auditLogs      AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Survey {
  id          String       @id @default(uuid())
  tenantId    String
  ownerId     String
  title       String
  description String?
  structure   Json         // SurveyDocument JSON
  status      SurveyStatus @default(draft)
  version     Int          @default(1)
  settings    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  publishedAt DateTime?
  closedAt    DateTime?

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner     User            @relation("SurveyOwner", fields: [ownerId], references: [id])
  versions  SurveyVersion[]
  responses Response[]
  sessions  RuntimeSession[]

  @@index([tenantId, status])
  @@index([ownerId])
}

model SurveyVersion {
  id            String   @id @default(uuid())
  surveyId      String
  versionNumber Int
  structure     Json
  createdAt     DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, versionNumber])
  @@index([surveyId])
}

model RuntimeSession {
  id             String         @id @default(uuid())
  surveyId       String
  surveyVersion  Int
  tenantId       String
  respondentId   String?
  status         ResponseStatus @default(started)
  embeddedData   Json           @default("{}")
  answers        Json           @default("{}")
  currentBlockId    String?
  currentQuestionId String?
  startedAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  completedAt    DateTime?

  survey   Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  response Response?

  @@index([surveyId, status])
  @@index([tenantId])
}

model Response {
  id            String         @id @default(uuid())
  surveyId      String
  surveyVersion Int
  tenantId      String
  sessionId     String?        @unique
  respondentId  String?
  status        ResponseStatus
  data          Json           @default("{}")
  answers       Json           @default("{}")
  startedAt     DateTime
  completedAt   DateTime?
  updatedAt     DateTime       @updatedAt

  survey  Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session RuntimeSession? @relation(fields: [sessionId], references: [id])

  @@index([surveyId, status])
  @@index([tenantId])
}

model WebhookSubscription {
  id        String   @id @default(uuid())
  tenantId  String
  url       String
  secret    String
  events    String[] // WebhookEventType[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs     WebhookLog[]

  @@index([tenantId, active])
}

model WebhookLog {
  id             String                @id @default(uuid())
  subscriptionId String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(pending)
  statusCode     Int?
  retries        Int                   @default(0)
  nextRetryAt    DateTime?
  createdAt      DateTime              @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
  @@index([status, nextRetryAt])
}

model ApiKey {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  keyHash   String   @unique
  prefix    String
  createdAt DateTime @default(now())
  revokedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}
