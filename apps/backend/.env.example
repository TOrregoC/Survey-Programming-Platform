# Backend-local env. Prisma CLI reads from this file when run inside apps/backend.
# Copy to .env and adjust for your environment.

NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

DATABASE_URL=postgresql://survey:survey@localhost:5432/survey_dev?schema=public

JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGIN=http://localhost:3000

REDIS_URL=redis://localhost:6379

WEBHOOK_SIGNING_SECRET=replace-me-with-another-long-random-secret
WEBHOOK_MAX_RETRIES=5
